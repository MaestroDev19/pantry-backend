APP_NAME=Pantry Server
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ALLOW_ORIGINS=["http://localhost:3000"]
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Prometheus text metrics at GET /metrics (default on).
# METRICS_ENABLED=true

# Stricter limits for POST /api/households/join (per IP before auth, per user after auth).
# Set *_ENABLED=false to disable; set a cap to 0 to disable that dimension only.
# HOUSEHOLDS_JOIN_RATE_LIMIT_ENABLED=true
# HOUSEHOLDS_JOIN_RATE_LIMIT_IP_PER_MINUTE=30
# HOUSEHOLDS_JOIN_RATE_LIMIT_USER_PER_MINUTE=10
#
# POST /api/ai/* — per client IP (reduces abuse of embeddings / recipe generation).
# AI_RATE_LIMIT_ENABLED=true
# AI_RATE_LIMIT_IP_PER_MINUTE=20
#
# POST /api/households/create|leave|convert-to-joinable|rename — per authenticated user.
# HOUSEHOLD_MUTATIONS_RATE_LIMIT_ENABLED=true
# HOUSEHOLD_MUTATIONS_USER_PER_MINUTE=30
# Only if behind a trusted proxy that sets the header (otherwise clients can spoof):
# TRUST_X_FORWARDED_FOR=false

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Local dev only: treat X-User-ID (UUID) as the authenticated user without Bearer.
# Never enable in production.
# AUTH_ALLOW_X_USER_ID=false

GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Optional: short TTL in-process read cache for list endpoints (default on, 45s)
# PANTRY_READ_CACHE_ENABLED=true
# PANTRY_READ_CACHE_TTL_SECONDS=45
